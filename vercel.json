{
    "rewrites": [
        {
            "source": "/studio/(.*)",
            "destination": "/studio/index.html"
        },
        {
            "source": "/generator",
            "destination": "/generator/index.html"
        },
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/:id",
            "destination": "/index.html"
        }
    ]
}
