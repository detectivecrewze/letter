{
    "rewrites": [
        {
            "source": "/studio/(.*)",
            "destination": "/studio/index.html"
        },
        {
            "source": "/generator/bundle",
            "destination": "/generator/bundle/index.html"
        },
        {
            "source": "/generator",
            "destination": "/generator/index.html"
        },
        {
            "source": "/bundle",
            "destination": "/bundle/index.html"
        },
        {
            "source": "/bundle/(.*)",
            "destination": "/bundle/index.html"
        },
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/airmail/:id",
            "destination": "/themes/airmail/index.html"
        },
        {
            "source": "/airmail",
            "destination": "/themes/airmail/index.html"
        },
        {
            "source": "/ribbon/:id",
            "destination": "/themes/ribbon/index.html"
        },
        {
            "source": "/ribbon",
            "destination": "/themes/ribbon/index.html"
        },
        {
            "source": "/:id",
            "destination": "/index.html"
        }
    ]
}
